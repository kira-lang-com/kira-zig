import bindings.callbacks as callbacks

@Main
@Native
function main() {
    print("callbacks")
    let result: I64 = callbacks.kira_invoke_callback(add_two, 0, 5)
    print(result)
    return
}

@Native
function add_two(value: I64, user_data: RawPtr): I64 {
    let sum: I64 = value + 2
    return sum
}
